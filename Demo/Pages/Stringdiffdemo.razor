@page "/stringdiffdemo"
@using Demo.Services
@using Demo.Stringdiffdemo
@using DimonSmart.StringDiff
@inject IDemoPageChromeService PageChrome

<PageTitle>StringDiff</PageTitle>
<div class="page-container">
    <div class="stringdiff-container">
        <div class="stringdiff-textareas">
            <div class="stringdiff-editor">
                <label class="stringdiff-editor__label" for="stringdiff-left">Original text</label>
                <textarea id="stringdiff-left" @bind="TextLeft" @oninput="OnTextLeftInput" placeholder="Enter text here..."></textarea>
            </div>
            <div class="stringdiff-editor">
                <label class="stringdiff-editor__label" for="stringdiff-right">Updated text</label>
                <textarea id="stringdiff-right" @bind="TextRight" @oninput="OnTextRightInput" placeholder="Enter text here..."></textarea>
            </div>
        </div>

        <div class="stringdiff-toolbar">
            <label class="demo-pill-toggle">
                <input type="checkbox" @bind="BreakOnWords" />
                <span>Try break on words</span>
            </label>
        </div>

        <div class="stringdiff-examples" aria-label="Example presets">
            <div class="stringdiff-examples__label">Examples</div>
            <div class="stringdiff-examples__list">
                <button type="button" class="@GetExampleButtonClass(1)" @onclick="SetExample1">Book quote</button>
                <button type="button" class="@GetExampleButtonClass(2)" @onclick="SetExample2">Poetry</button>
                <button type="button" class="@GetExampleButtonClass(3)" @onclick="SetExample3">Numbers</button>
                <button type="button" class="@GetExampleButtonClass(4)" @onclick="SetExample4">Program code</button>
                <button type="button" class="@GetExampleButtonClass(5)" @onclick="SetExample5">Recipe</button>
            </div>
        </div>

        <DiffViewBox HeaderText="Text differences" Diff="@_stringDiffHighlightedResult" />
    </div>
</div>
@code {
    protected override void OnInitialized()
    {
        base.OnInitialized();
        PageChrome.SetPage("StringDiff");
    }

    private string _textLeft = string.Empty;
    private int? _selectedExampleId;

    private string TextLeft
    {
        get => _textLeft;
        set
        {
            if (_textLeft == value) return;
            _textLeft = value;
            CalculateDiff();
        }
    }

    private string _textRight = string.Empty;
    private string TextRight
    {
        get => _textRight;
        set
        {
            if (_textRight == value) return;
            _textRight = value;
            CalculateDiff();
        }
    }

    private bool _breakOnWords;
    private bool BreakOnWords
    {
        get => _breakOnWords;
        set
        {
            if (_breakOnWords == value) return;
            _breakOnWords = value;
            CalculateDiff();
        }
    }

    private TextDiff? _stringDiffHighlightedResult;

    private void CalculateDiff()
    {
        var options = new StringDiffOptions(BreakOnWords ? SimpleTokenBoundaryDetector.Instance : null);
        var stringDiff = new StringDiff(options);
        _stringDiffHighlightedResult = stringDiff.ComputeDiff(TextLeft, TextRight);
    }

    private void OnTextLeftInput(ChangeEventArgs e)
    {
        _selectedExampleId = null;
        TextLeft = e.Value?.ToString() ?? string.Empty;
    }

    private void OnTextRightInput(ChangeEventArgs e)
    {
        _selectedExampleId = null;
        TextRight = e.Value?.ToString() ?? string.Empty;
    }

    private void SetExample1()
    {
        ApplyExample(
            1,
            "It was the best of times, it was the worst of times.",
            "It was the age of wisdom, it was the age of foolishness.");
    }

    private void SetExample2()
    {
        ApplyExample(
            2,
            "The woods are lovely, dark and deep,\nBut I have promises to keep,\nAnd miles to go before I sleep,\nAnd miles to go before I sleep.",
            "The woods are lovely, dark and deep,\nBut I have promises to keep,\nAnd kilometers to go before I sleep,\nAnd kilometers to go before I sleep.");
    }

    private void SetExample3()
    {
        ApplyExample(
            3,
            "2 x 2 = 5\n3 x 3 = 9\n4 x 4 = 16",
            "2 x 2 = 4\n3 x 3 = 9\n4 x 4 = 20");
    }

    private void SetExample4()
    {
        ApplyExample(
            4,
            "public void Example()\n{\n    Console.WriteLine(\"hello, world!\");\n}",
            "public void Example()\n{\n    Console.WriteLine(\"Hello, universe!\");\n}");
    }

    private void SetExample5()
    {
        ApplyExample(
            5,
            "Ingredients:\n- 1 cup sugar\n- 2 cups flour\n- 1/2 cup butter",
            "Ingredients:\n- 1 big cup sugar\n- 3 cups flour\n- 1/2 cup margarine");
    }

    private void ApplyExample(int exampleId, string leftText, string rightText)
    {
        _selectedExampleId = exampleId;
        _textLeft = leftText;
        _textRight = rightText;
        CalculateDiff();
    }

    private string GetExampleButtonClass(int exampleId)
        => exampleId == _selectedExampleId
            ? "demo-pill-button demo-pill-button--active"
            : "demo-pill-button";
}
