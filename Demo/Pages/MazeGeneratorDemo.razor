@page "/mazegeneratordemo"

@using Demo.Components
@using Demo.Demos.MazePathFinder
@using Demo.Demos.TSM
@using Demo.Services
@using DimonSmart.MazeGenerator
@inject IDemoPageChromeService PageChrome

@inherits MazeBaseComponent<MazeCellModel>

@implements IMazePlotter

<PageTitle>Maze Generator Demo</PageTitle>

<div class="page-container maze-generator-page">
    <section class="demo-panel demo-panel--compact maze-generator-controls">
        <div class="maze-generator-controls__header">
            <div class="maze-generator-controls__copy">
                <h2 class="demo-section-title">Build settings</h2>
                <p class="demo-muted-note">Adjust maze size and carving behavior, then generate a fresh layout.</p>
            </div>
            <button type="button"
                    class="demo-pill-button demo-pill-button--primary maze-generator-controls__action"
                    @onclick="GenerateMazeAsync"
                    disabled="@_generationInProgress">
                @(_generationInProgress ? "Generating..." : "Generate maze")
            </button>
        </div>

        <div class="maze-generator-controls__grid">
            <section class="demo-control-card demo-control-card--compact maze-generator-controls__size-card">
                <div class="maze-generator-controls__size-grid">
                    <label class="demo-input-field">
                        <span class="demo-field-label">Width</span>
                        <input class="demo-input" type="number" min="1" max="101" step="2" @bind="XSize" />
                    </label>
                    <label class="demo-input-field">
                        <span class="demo-field-label">Height</span>
                        <input class="demo-input" type="number" min="1" max="101" step="2" @bind="YSize" />
                    </label>
                </div>
            </section>

            <section class="demo-control-card demo-control-card--compact">
                <div class="demo-slider-header">
                    <span class="demo-field-label">Emptiness</span>
                    <span class="demo-value-pill">@Emptiness%</span>
                </div>
                <input class="demo-slider" type="range" min="0" max="100" @bind-value="Emptiness" @bind-value:event="oninput" />
                <p class="demo-control-note">Higher values create wider open spaces and fewer solid blocks.</p>
            </section>

            <section class="demo-control-card demo-control-card--compact">
                <div class="demo-slider-header">
                    <span class="demo-field-label">Wall shortness</span>
                    <span class="demo-value-pill">@WallShortness%</span>
                </div>
                <input class="demo-slider" type="range" min="0" max="100" @bind-value="WallShortness" @bind-value:event="oninput" />
                <p class="demo-control-note">Higher values break long walls into shorter segments.</p>
            </section>

            <section class="demo-control-card demo-control-card--compact maze-generator-controls__toggle-card">
                <label class="demo-pill-toggle demo-pill-toggle--compact">
                    <input type="checkbox" @bind="IsSlowVisualization" />
                    <span>Slow visualization</span>
                </label>
                <p class="demo-control-note">Animate carving step by step instead of drawing only the final maze.</p>
            </section>
        </div>
    </section>

    <div id="MazeContainerId" class="demo-canvas-host maze-generator-canvas">
        @if (_maze != null)
        {
            <MazeDisplay TCell="MazeCellModel" Maze="_maze">
                <CellTemplate Context="cell">
                    <MazeCell X="@cell.X" Y="@cell.Y" Cell="@cell.Cell" />
                </CellTemplate>
            </MazeDisplay>
        }
    </div>
</div>
@code {
    private bool _generationInProgress = false;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        PageChrome.SetPage("Maze Generator", PageSurfaceMode.Immersive);
    }

    protected override async Task GenerateMazeAsync()
    {
        if (_generationInProgress) return;
        _generationInProgress = true;
        try
        {
            CancelGeneration();
            var options = new MazeBuildOptions(WallShortness / 100, Emptiness / 100.0);
            _maze = new Maze<MazeCellModel>(XSize, YSize);
            var mazeBuilder = new MazeBuilder<MazeCellModel>(_maze, options);
            await mazeBuilder.BuildAsync(this, CancellationTokenSource.Token);
            StateHasChanged();
        }
        finally
        {
            _generationInProgress = false;
        }
    }

    private string GetCellColor(int x, int y) => _maze?.IsWall(x, y) ?? false ? "black" : "white";

    private static Func<int, int, bool> GetEndPointCriteria(int endX, int endY)
    {
        return (x, y) => x == endX && y == endY;
    }

    public async Task PlotPassageAsync(int x, int y)
    {
        StateHasChanged();
        await Task.Delay(50);
    }

    public async Task PlotWallAsync(int x, int y)
    {
        if (!IsSlowVisualization) return;
        StateHasChanged();
        var delay = TimeSpan.FromMilliseconds(50);
        await Task.Delay(delay);
    }
}
