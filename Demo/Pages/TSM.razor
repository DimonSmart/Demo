@page "/tsm"
@using Demo.Components
@using Demo.Demos.TSM
@using Demo.Services
@using GeneticAlgorithm.GeneralGenetic
@inject IDemoPageChromeService PageChrome

<PageTitle>Travelling Salesman</PageTitle>

<div class="page-container tsm-page">
    <section class="tsm-controls-strip-wrap">
        <div class="demo-control-strip demo-control-strip--fit tsm-controls-strip">
            <label class="demo-inline-editor"
                   for="tsm-population-size"
                   title="How many candidate routes are kept in each generation.">
                <span class="demo-summary-item__label">Population</span>
                <input id="tsm-population-size" class="demo-input demo-input--compact demo-inline-editor__input" type="number" @bind="PopulationSize" min="@PopulationSizeMin" max="@PopulationSizeMax" />
            </label>

            <span class="demo-summary-separator">&middot;</span>

            <label class="demo-inline-editor"
                   for="tsm-elite-size"
                   title="Top routes preserved to seed the next generation.">
                <span class="demo-summary-item__label">Elite</span>
                <input id="tsm-elite-size" class="demo-input demo-input--compact demo-inline-editor__input" type="number" @bind="EliteChromosomes" min="@EliteChromosomesMin" max="@EliteChromosomesMax" />
            </label>

            <span class="demo-summary-separator">&middot;</span>

            <label class="demo-inline-editor"
                   for="tsm-crossover-count"
                   title="Routes rebuilt by mixing existing candidates on each step.">
                <span class="demo-summary-item__label">Crossover</span>
                <input id="tsm-crossover-count" class="demo-input demo-input--compact demo-inline-editor__input" type="number" @bind="CrossoverCount" min="@CrossoverCountMin" max="@CrossoverCountMax" />
            </label>

            <span class="demo-summary-separator">&middot;</span>

            <label class="demo-inline-editor"
                   for="tsm-mutation-count"
                   title="Cloned routes that receive random changes before scoring.">
                <span class="demo-summary-item__label">Mutation</span>
                <input id="tsm-mutation-count" class="demo-input demo-input--compact demo-inline-editor__input" type="number" @bind="MutationCount" min="@MutationCountMin" max="@MutationCountMax" />
            </label>

            <span class="demo-summary-separator">&middot;</span>

            <label class="demo-inline-editor"
                   for="tsm-city-count"
                   title="How many cities are generated for the travelling salesman problem.">
                <span class="demo-summary-item__label">Cities</span>
                <input id="tsm-city-count" class="demo-input demo-input--compact demo-inline-editor__input" type="number" @bind="CityCount" min="@CityCountMin" max="@CityCountMax" />
            </label>

            <div class="demo-control-strip__actions tsm-controls-strip__actions">
                <button type="button"
                        class="demo-pill-button tsm-controls-strip__action"
                        @onclick="InitializeGenetic"
                        disabled="@_runInProgress">
                    @(Genetic == null ? "Start" : "Restart")
                </button>

                <label class="demo-inline-editor"
                       for="tsm-run-limit"
                       title="How many generations to execute when using Run.">
                    <span class="demo-summary-item__label">Run limit</span>
                    <input id="tsm-run-limit" class="demo-input demo-input--compact demo-inline-editor__input" type="number" @bind="RunIterationsLimit" min="@RunIterationsLimitMin" max="@RunIterationsLimitMax" />
                </label>

                <button type="button"
                        class="demo-pill-button demo-pill-button--primary tsm-controls-strip__action"
                        @onclick="HandleRunActionAsync">
                    @RunActionText
                </button>

                <button type="button"
                        class="demo-pill-button tsm-controls-strip__action"
                        @onclick="RunStepAsync"
                        disabled="@_runInProgress">
                    Step
                </button>
            </div>
        </div>
    </section>

    <section class="demo-panel tsm-stage">
        @if (HasResult)
        {
            <div class="demo-summary-strip tsm-stage__summary">
                <div class="demo-summary-item">
                    <span class="demo-summary-item__label">Best</span>
                    <span class="demo-summary-item__value">@BestScore</span>
                </div>
                <span class="demo-summary-separator">&middot;</span>
                <div class="demo-summary-item">
                    <span class="demo-summary-item__label">Steps</span>
                    <span class="demo-summary-item__value">@TotalIterations</span>
                </div>
                <span class="demo-summary-separator">&middot;</span>
                <div class="demo-summary-item">
                    <span class="demo-summary-item__label">Last run</span>
                    <span class="demo-summary-item__value">@LastRunIterations</span>
                </div>
                <span class="demo-summary-separator">&middot;</span>
                <div class="demo-summary-item">
                    <span class="demo-summary-item__label">Cities</span>
                    <span class="demo-summary-item__value">@CityCount</span>
                </div>
            </div>

            <div class="tsm-map-shell">
                <TspMapComponent ProblemData="TsmProblemData"
                                 BestSolution="BestResult"
                                 Width="100%"
                                 Height="100%"
                                 class="map-component" />
            </div>
        }
        else
        {
            <div class="tsm-stage__empty">
                <h2 class="demo-section-title">Route map</h2>
                <p class="demo-muted-note">Set the algorithm parameters and run the solver to generate a city map and the current best route.</p>
            </div>
        }
    </section>
</div>

@code {
    protected override void OnInitialized()
    {
        base.OnInitialized();
        PageChrome.SetPage("Travelling Salesman", PageSurfaceMode.Immersive);
    }

    private int PopulationSizeValue { get; set; } = 1000;
    private const int PopulationSizeMin = 10;
    private const int PopulationSizeMax = 10000;

    private int PopulationSize
    {
        get => PopulationSizeValue;
        set
        {
            if (value < PopulationSizeMin || value > PopulationSizeMax || value == PopulationSizeValue) return;
            PopulationSizeValue = value;
        }
    }

    private int EliteChromosomesValue { get; set; } = 50;
    private const int EliteChromosomesMin = 1;
    private const int EliteChromosomesMax = 100;

    private int EliteChromosomes
    {
        get => EliteChromosomesValue;
        set
        {
            if (value < EliteChromosomesMin || value > EliteChromosomesMax || value == EliteChromosomesValue) return;
            EliteChromosomesValue = value;
        }
    }

    private int CrossoverCountValue { get; set; } = 25;
    private const int CrossoverCountMin = 1;
    private const int CrossoverCountMax = 100;

    private int CrossoverCount
    {
        get => CrossoverCountValue;
        set
        {
            if (value < CrossoverCountMin || value > CrossoverCountMax || value == CrossoverCountValue) return;
            CrossoverCountValue = value;
        }
    }

    private int MutationCountValue { get; set; } = 25;
    private const int MutationCountMin = 1;
    private const int MutationCountMax = 100;

    private int MutationCount
    {
        get => MutationCountValue;
        set
        {
            if (value < MutationCountMin || value > MutationCountMax || value == MutationCountValue) return;
            MutationCountValue = value;
        }
    }

    private int CityCountValue { get; set; } = 10;
    private const int CityCountMin = 1;
    private const int CityCountMax = 100;

    private int CityCount
    {
        get => CityCountValue;
        set
        {
            if (value < CityCountMin || value > CityCountMax || value == CityCountValue) return;
            CityCountValue = value;
        }
    }

    private int RunIterationsLimitValue { get; set; } = 1000;
    private const int RunIterationsLimitMin = 1;
    private const int RunIterationsLimitMax = 1000000;

    private int RunIterationsLimit
    {
        get => RunIterationsLimitValue;
        set
        {
            if (value < RunIterationsLimitMin || value > RunIterationsLimitMax || value == RunIterationsLimitValue) return;
            RunIterationsLimitValue = value;
        }
    }

    private bool _runInProgress;
    private int LastRunIterations { get; set; }
    private int TotalIterations { get; set; }
    private TsmProblemData? TsmProblemData { get; set; }
    private Genetic<TsmChromosome>? Genetic { get; set; }
    private ChromosomeWithScore<TsmChromosome>? BestResult => Genetic?.GetBestResult();
    private int BestScore => BestResult?.Score ?? 0;
    private bool HasResult => TsmProblemData != null && BestResult != null;
    private bool _stopRequested;
    private string RunActionText => _runInProgress ? "Stop" : "Run";

    private void InitializeGenetic()
    {
        var geneticAlgorithmSettings = new GeneticAlgorithmSettings
        {
            Population = PopulationSize,
            BestChromosomes = EliteChromosomes,
            CrossoverChromosomes = CrossoverCount,
            MutationChromosomes = MutationCount
        };

        var randomProvider = RandomProvider.Shared;
        var tsmProblemDataFactory = new TsmProblemDataFactory(randomProvider);
        TsmProblemData = tsmProblemDataFactory.Create(CityCount, 200, 200);

        var mutator = new TsmChromosomeMutator(randomProvider);
        var crossoverer = new TsmChromosomeCrossoverer(randomProvider);
        var chromosomeFactory = new TsmChromosomeFactory(TsmProblemData.Cities.Length, randomProvider);
        var fitnessFunction = new TsmFitnessFunction(TsmProblemData);
        Genetic = new Genetic<TsmChromosome>(geneticAlgorithmSettings, mutator, crossoverer, chromosomeFactory, fitnessFunction);
        LastRunIterations = 0;
        TotalIterations = 0;
        StateHasChanged();
    }

    private void EnsureGeneticInitialized()
    {
        if (Genetic == null)
        {
            InitializeGenetic();
        }
    }

    private Task RunStepAsync()
    {
        EnsureGeneticInitialized();
        return ExecuteIterationsAsync(1);
    }

    private Task HandleRunActionAsync()
    {
        if (_runInProgress)
        {
            _stopRequested = true;
            return Task.CompletedTask;
        }

        EnsureGeneticInitialized();
        return RunIterationsAsync();
    }

    private Task RunIterationsAsync() => ExecuteIterationsAsync(RunIterationsLimit);

    private async Task ExecuteIterationsAsync(int iterationCount)
    {
        if (_runInProgress || Genetic == null || iterationCount <= 0)
        {
            return;
        }

        _runInProgress = true;
        _stopRequested = false;
        LastRunIterations = 0;

        try
        {
            for (var i = 0; i < iterationCount; i++)
            {
                if (_stopRequested)
                {
                    break;
                }

                Genetic.NextIteration();
                LastRunIterations++;
                TotalIterations++;
                StateHasChanged();
                await Task.Yield();
                await Task.Delay(1);
            }
        }
        finally
        {
            _stopRequested = false;
            _runInProgress = false;
            StateHasChanged();
        }
    }

}

