<div id="@Id" class="rotation-control">
    <button type="button" class="demo-pill-button rotation-control__button" @onclick="RotateLeft">
        &#x21BA; Left
    </button>
    <span class="demo-value-pill rotation-indicator">@Rotation&deg;</span>
    <button type="button" class="demo-pill-button rotation-control__button" @onclick="RotateRight">
        Right &#x21BB;
    </button>
</div>

@code {
    [Parameter]
    [EditorRequired]
    public required string Id { get; set; }

    [Parameter]
    public int Rotation { get; set; }

    [Parameter]
    public EventCallback<int> RotationChanged { get; set; }

    private void RotateLeft()
    {
        Rotation = (Rotation - 90 + 360) % 360;
        RotationChanged.InvokeAsync(Rotation);
    }

    private void RotateRight()
    {
        Rotation = (Rotation + 90) % 360;
        RotationChanged.InvokeAsync(Rotation);
    }
}
