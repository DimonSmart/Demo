@using Demo.Demos.BJ

<div class="player-hands-container @Class">
    @if (Game.CurrentGameState == BlackjackGameBase.GameState.GameNotStarted)
    {
        <div>Deal cards</div>
    }
    else
    {
        @foreach (var hand in Game.PlayerHands)
        {
            <div class="hand-wrapper @(hand == Game.CurrentPlayerHand ? "current-hand" : "")">
                <PlayingHand Hand="@hand"/>
            </div>
        }
    }
</div>

@code {
    [Parameter] public required BlackjackGameBase Game { get; set; }
    [Parameter] public string? Class { get; set; }
}

