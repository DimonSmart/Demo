@using Demo.Abstractions
@using Demo.Components
@inherits LayoutComponentBase
@implements IDisposable

@inject IDemoPageChromeService PageChrome

<CascadingValue Value="this">
    <div class="page layout-shell @(IsImmersive ? "layout-shell--immersive" : "layout-shell--utility")">
        <aside class="sidebar">
            <NavMenu />
        </aside>

        <main class="layout-main">
            <div class="top-row @(IsImmersive ? "top-row--immersive" : "top-row--utility")">
                <div class="top-row__title">
                    @if (!string.IsNullOrWhiteSpace(PageEyebrow))
                    {
                        <div class="top-row__eyebrow">@PageEyebrow</div>
                    }
                    <div class="heading-text">@PageHeading</div>
                </div>

                <div class="top-row__actions">
                    <a href="https://www.buymeacoffee.com/DimonSmart" target="_blank" class="support-link" rel="noreferrer">
                        <img src="https://cdn.buymeacoffee.com/buttons/v2/default-yellow.png"
                             alt="Buy Me A Coffee"
                             class="support-link__image">
                    </a>
                    <a href="https://www.linkedin.com/in/dimonsmart/"
                       target="_blank"
                       rel="noreferrer"
                       class="btn btn-outline-secondary btn-sm rounded-pill">
                        <i class="fab fa-linkedin"></i> LinkedIn
                    </a>
                    <button class="btn btn-primary btn-sm rounded-pill" @onclick="ShowFeedback">Feedback</button>
                </div>
            </div>

            <article class="content @(IsImmersive ? "content--immersive" : "content--utility")">
                @Body
            </article>

            <Feedback @ref="feedbackComponent" />
        </main>
    </div>
</CascadingValue>

@code {
    private DemoPageDescriptor CurrentPage { get; set; } = new("Demo", PageSurfaceMode.Utility);
    private bool IsImmersive => CurrentPage.Mode == PageSurfaceMode.Immersive;
    private string PageHeading => string.IsNullOrWhiteSpace(CurrentPage.Title) ? "Demo" : CurrentPage.Title;
    private string? PageEyebrow => string.IsNullOrWhiteSpace(CurrentPage.EyebrowText) ? null : CurrentPage.EyebrowText;

    private Feedback feedbackComponent = null!;

    protected override void OnInitialized()
    {
        CurrentPage = PageChrome.Current;
        PageChrome.CurrentChanged += OnCurrentPageChanged;
    }

    private async Task OnCurrentPageChanged(DemoPageDescriptor descriptor)
    {
        CurrentPage = descriptor;
        await InvokeAsync(StateHasChanged);
    }

    private async Task ShowFeedback()
    {
        if (feedbackComponent != null)
        {
            await feedbackComponent.OpenAsync();
        }
    }

    public void Dispose()
    {
        PageChrome.CurrentChanged -= OnCurrentPageChanged;
    }
}
