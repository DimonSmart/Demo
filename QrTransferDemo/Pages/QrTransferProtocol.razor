@page "/qr-transfer/protocol"

@using Markdig
@using System.IO
@using System.Reflection

<PageTitle>QR transfer - protocol</PageTitle>

<div class="container">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
        <h1 class="h3 mb-0">How QR-based data transfer works</h1>
        <a class="btn btn-outline-primary" href="/qr-transfer/send">Back to sender</a>
    </div>

    @if (_isLoading)
    {
        <div class="text-muted">Loading protocol description...</div>
    }
    else if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger" role="alert">@_errorMessage</div>
    }
    else if (!string.IsNullOrEmpty(_protocolHtml))
    {
        <article class="markdown-body">@((MarkupString)_protocolHtml)</article>
    }
</div>

@code {
    private bool _isLoading = true;
    private string? _protocolHtml;
    private string? _errorMessage;

    [Inject] private IDemoPageChromeService PageChrome { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        PageChrome.SetPage("QR transfer - protocol");

        try
        {
            var assembly = typeof(QrTransferProtocol).Assembly;
            using var stream = assembly.GetManifestResourceStream("QrTransferDemo.Docs.QrTransferDataFlow.md");

            if (stream is null)
            {
                _errorMessage = "Failed to load the protocol description.";
                return;
            }

            using var reader = new StreamReader(stream);
            var markdown = await reader.ReadToEndAsync();
            var pipeline = new MarkdownPipelineBuilder()
                .UseAdvancedExtensions()
                .UsePipeTables()
                .UseTaskLists()
                .Build();
            _protocolHtml = Markdown.ToHtml(markdown, pipeline);
        }
        catch
        {
            _errorMessage = "Failed to load the protocol description.";
        }
        finally
        {
            _isLoading = false;
        }
    }
}
